# Environment variables specified in this way will always be included in the JavaScript bundle,
# prefixing the environment variable name with "NEXT_PUBLIC_" only has an effect when specifying them through the environment or .env files.
# https://nextjs.org/docs/basic-features/environment-variables

NODE_ENV = "development"
NEXT_PUBLIC_APP_NAME = "project_name"
NEXT_PUBLIC_APP_PORT = 8080
NEXT_PUBLIC_APP_TZ = "Asia/Bangkok"

NEXT_PUBLIC_WEB_TITLE = ""
NEXT_PUBLIC_BASE_URL = "http://localhost:8080"
NEXT_PUBLIC_API_GATEWAY = "http://localhost:3000"

NEXT_PUBLIC_SUPABASE_URL = "your-project-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY = "your-anon-key"

# Various time formats [https://github.com/vercel/ms]
NEXT_PUBLIC_JWT_SECRET = ""
NEXT_PUBLIC_JWT_TTL = "1h"
